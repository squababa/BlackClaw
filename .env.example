# BlackClaw Environment Variables
# Copy this file to .env and fill in your keys
# NEVER commit .env to version control
# Required
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
# Provider selection
# LLM_PROVIDER=claude
# BLACKCLAW_MODEL=claude-sonnet-4-6
# LLM_PROVIDER=gemini
# BLACKCLAW_MODEL=gemini-2.5-flash
# LLM_PROVIDER=ollama
# BLACKCLAW_MODEL=qwen3:8b
# Optional (defaults shown)
# OLLAMA_BASE_URL=http://localhost:11434
# BLACKCLAW_THRESHOLD=0.6
# BLACKCLAW_COOLDOWN=300
# BLACKCLAW_DB_PATH=blackclaw.db
# BLACKCLAW_MAX_PATTERNS=3
# BLACKCLAW_MAX_TAVILY=10
# BLACKCLAW_MAX_LLM=5
